---
import Layout from "@/layouts/Layout.astro";
---

<Layout>
  <section id="hero" class="relative flex min-h-screen">
    <div class="hero-grid-pattern absolute inset-0 opacity-[0.022]"></div>
    <div
      class="hero-scanlines pointer-events-none absolute inset-0 opacity-[0.015]"
    >
    </div>
    <div
      class="hero-scanline-traveler pointer-events-none absolute inset-x-0 top-0 h-[2px] opacity-20"
    >
    </div>
    <div class="container flex w-full items-center justify-between">
      <div class="flex max-w-6xl min-w-0 flex-1 flex-col space-y-3">
        <h1
          class="font-heading text-4xl tracking-tight md:text-6xl lg:text-7xl"
        >
          <span>I'm</span>
          <span class="text-primary relative inline-block font-bold">
            Daniel Sánchez
            <span
              class="from-primary via-primary/60 absolute right-0 -bottom-1 left-0 h-px bg-linear-to-r to-transparent"
            ></span>
          </span>
        </h1>
        <h2
          class="font-heading text-accent-foreground mb-6 h-8 text-lg font-semibold tracking-wide md:h-10 md:text-2xl"
        >
          > Fullstack & Game Developer
        </h2>
        <p class="text-balance">
          Crafting immersive game experiences with 8+ years of expertise in
          real-time systems, gameplay programming, and technical design.
        </p>
        <p class="text-balance">
          Passionate about pushing the boundaries of interactive entertainment
          through elegant code and creative problem-solving.
        </p>
      </div>
      <div
        class="border-primary/5 relative h-96 w-72 shrink-0 rounded-lg border px-4 pb-3 md:h-112 md:w-96"
      >
        <div
          class="glow-primary pointer-events-none absolute -inset-16 -z-10 opacity-5 mix-blend-screen blur-xl"
        >
        </div>

        <div
          class="border-primary/10 absolute inset-4 flex items-end justify-center overflow-visible rounded-md border px-5 pb-3"
        >
          <img
            class="h-[120%] w-full rounded-lg object-cover object-top"
            src="/images/daniel_all.webp"
            alt="Retrato de Daniel Sánchez"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .glow-primary {
    background:
      radial-gradient(
        circle at 50% 65%,
        rgba(25, 212, 229, 0.75) 0%,
        rgba(25, 212, 229, 0.35) 35%,
        transparent 70%
      ),
      radial-gradient(
        circle at 30% 30%,
        rgba(25, 212, 229, 0.35) 0%,
        transparent 60%
      );
  }

  .hero-grid-pattern {
    background:
      linear-gradient(var(--color-primary) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-primary) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .hero-scanlines {
    background: repeating-linear-gradient(
      0deg,
      transparent 0px 2px,
      var(--color-primary) 2px 4px
    );
  }

  .hero-scanline-traveler {
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-primary),
      transparent
    );
    animation: hero-scanline-travel 5s infinite linear;
  }

  @keyframes hero-scanline-travel {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(100vh);
    }
  }
</style>
