---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle = "" } = Astro.props;
---

<div class="container">
  <p class="text-primary mb-2 font-mono text-xs tracking-[0.3em] uppercase">
    {subtitle}
  </p>
  <h2 class="font-heading text-3xl font-bold">{title}</h2>
  <div class="from-primary mt-3 h-px w-16 bg-linear-to-r to-transparent"></div>
</div>
