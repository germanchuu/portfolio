---
import { Image } from "astro:assets";
import portraitImage from "@/assets/images/me/daniel_all.webp";
---

<div
  class="border-primary/5 motion-preset-expand motion-opacity-in-0 motion-delay-300 relative h-96 w-72 shrink-0 rounded-lg border px-4 pb-3 duration-700 md:h-112 md:w-96"
>
  <div
    class="glow-primary pointer-events-none absolute -inset-16 -z-10 opacity-5 mix-blend-screen blur-xl"
  >
  </div>

  <div
    class="border-primary/10 absolute inset-4 flex items-end justify-center overflow-visible rounded-md border px-5 pb-3"
  >
    <Image
      class="h-[120%] w-full rounded-lg object-cover object-top"
      src={portraitImage}
      alt="Retrato de Daniel Sánchez"
    />
  </div>
</div>
